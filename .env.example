# Production / deploy reference for Coolify and other hosted environments.
# Do not copy this file to .env.local — use .env.local.example for local development.
#
# One codebase, four deployment profiles:
#   main        defillama.com
#   investors   investors.defillama.com
#   staging     investors preview (same stack as investors; preview flag enabled)
#   enterprise  enterprise.defillama.com
#
# Investor profiles (investors, staging, enterprise) share the same env block below.
# Only these two vars pick the view:
#   NEXT_PUBLIC_INVESTORS_SITE=investors     # investors prod + staging
#   NEXT_PUBLIC_INVESTORS_SITE=enterprise    # enterprise prod
#   NEXT_PUBLIC_INVESTORS_PREVIEW=true       # staging only (uncomment / set on staging deploy)

# =============================================================================
# SHARED — all self-hosted Coolify deployments
# =============================================================================

API_KEY=
CG_KEY=
LLAMA_DB_URL=
NEXT_PUBLIC_SEARCH_API_TOKEN=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
CORS_ALLOWED_ORIGINS=

IS_RUNTIME=true
REDIS_URL=

BUILD_DEPLOYMENT_NAME=
BUILD_NOTIFY_USERS=
BUILD_STATUS_WEBHOOK=
LOGGER_API_KEY=
LOGGER_API_URL=

NEXT_TELEMETRY_DISABLED=1
# Self-hosted builds only. Do not set on Vercel — the build wrapper scopes heap for next build.
NODE_OPTIONS=--max_old_space_size=8192

ROUND_UP_BOT_TOKEN=
TASTY_API_KEY=
TASTY_API_URL=

# =============================================================================
# MAIN PRODUCTION ONLY (defillama.com)
# Add these on top of SHARED. Do not set NEXT_PUBLIC_INVESTORS_* on main.
# =============================================================================

ROBOTS_ALLOW_INDEXING=true

OPS_TELEMETRY_URL=
OPS_TELEMETRY_TOKEN=
OPS_TELEMETRY_TARGET_ID=

# Direct upstream overrides (take precedence over pro-api routing).
# EQUITIES_SECRET_KEY falls back to API2_SECRET_KEY when unset.
API2_SECRET_KEY=
BRIDGES_SERVER_URL=
COINS_SERVER_URL=
DATASETS_SERVER_URL=
EQUITIES_SERVER_URL=
EQUITIES_SECRET_KEY=
ETF_SERVER_URL=
FDV_SERVER_URL=
LIQUIDATIONS_SECRET_KEY=
LIQUIDATIONS_SERVER_URL_V2=
RISK_SERVER_URL=
RWA_PERPS_SERVER_URL=
RWA_SERVER_URL=
SERVER_URL=
STABLECOINS_SERVER_URL=
TRADFI_API=
V2_SERVER_URL=
YIELDS_SERVER_URL=

REVALIDATE_SECRET=
REVALIDATE_INSTANCES=
REVALIDATE_HOST_HEADER=

CF_ZONE=
CF_PURGE_CACHE_AUTH=

RCLONE_CONFIG_ARTIFACTS_ACCESS_KEY_ID=
RCLONE_CONFIG_ARTIFACTS_ENDPOINT=
RCLONE_CONFIG_ARTIFACTS_SECRET_ACCESS_KEY=

# =============================================================================
# INVESTOR DEPLOYMENTS (investors / staging / enterprise)
# Use SHARED vars above plus the block below. Omit the MAIN PRODUCTION section.
# =============================================================================

IR_SERVER_URL=

# --- pick one profile ---
NEXT_PUBLIC_INVESTORS_SITE=investors
# NEXT_PUBLIC_INVESTORS_PREVIEW=true

# enterprise profile instead:
# NEXT_PUBLIC_INVESTORS_SITE=enterprise
