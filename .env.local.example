# Copy to .env.local for local development.
# cp .env.local.example .env.local

# =============================================================================
# Required for local development
# =============================================================================
# Routes upstream calls through pro-api. Without API_KEY, constants fall back to
# per-domain public URLs (bridges.llama.fi, yields.llama.fi, etc.) — most of those
# are not valid for local page loads and you will hit rate limits. api.llama.fi and
# coins.llama.fi are the main exceptions that still work without a key.

API_KEY=

# CoinGecko Pro API key. Without it, direct CoinGecko calls use the free public API
# (api.coingecko.com) and rate-limit quickly. Affects token pages, protocol/chain chart
# overlays, unlocks pricing, correlations, adapter metrics, and metadata builds that
# call fetchCoinGeckoCoinsList (e.g. LlamaSwap dataset).

CG_KEY=

# =============================================================================
# Optional shared vars
# =============================================================================

NEXT_PUBLIC_SEARCH_API_TOKEN=

# =============================================================================
# Optional integrations
# =============================================================================
# Pro Dashboard unified table, P/F–P/S charts, and CEX analytics read Postgres.
# Leave unset unless you are working on those features; set it for faster /pro loads.
# LLAMA_DB_URL=

# =============================================================================
# View selection — default is main DefiLlama on http://localhost:3000
# =============================================================================
# Leave NEXT_PUBLIC_INVESTORS_SITE unset for the main site.
#
# Investors dashboard local dev — set ONE profile, then run `bun dev`:
#
#   investors (production parity):
#     NEXT_PUBLIC_INVESTORS_SITE=investors
#
#   investors staging (includes preview projects):
#     NEXT_PUBLIC_INVESTORS_SITE=investors
#     NEXT_PUBLIC_INVESTORS_PREVIEW=true
#
#   enterprise:
#     NEXT_PUBLIC_INVESTORS_SITE=enterprise
#
# Partner dashboard upstream APIs (spark, flare, sonic, near, berachain, etc.)
# require IR_SERVER_URL when working on investor routes locally:
#
# IR_SERVER_URL=
